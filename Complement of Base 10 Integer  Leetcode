class Solution {
public:
    int bitwiseComplement(int n) {
        // base case
        if (n==0) return 1;
        int ans = 0;
        int len = log2(n) + 1;
        for (int i = 0; len > i; i++) {
            if((n&(1<<i))==0) {
                ans = ans | (1 << i);
            }
        }
        return ans;
    }
};
