class Solution {
public:
    int lastStoneWeight(vector<int>& arr) {
        priority_queue<int> pq;
        for (auto x : arr)
            pq.push(x);
        while (pq.size() > 1) {
            int fir = pq.top();
            pq.pop();
            int sec = pq.top();
            pq.pop();
            pq.push(fir-sec);
        }
        if (pq.empty())
            return 0;
        return pq.top();
    }
};
