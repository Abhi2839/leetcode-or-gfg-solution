class Solution {
public:
    vector<int> arrayChange(vector<int>& nums, vector<vector<int>>& op) {
        int m = op.size();
        unordered_map<int, int> mp;
        for (int i = 0; nums.size() > i; i++) {
            mp[nums[i]] = i;
        }

        for (int i = 0; m > i; i++) {
           int a=op[i][0];
           int b=op[i][1];

           
           nums[mp[a]]=b;
           mp[b]=mp[a];
        }
        return nums;
    }
};
