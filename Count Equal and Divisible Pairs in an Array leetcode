class Solution {
public:
    int countPairs(vector<int>& nums, int k) {
        int cnt = 0;
        int n = nums.size();
        for (int i = 0; n > i; i++) {
            for (int j = i + 1; n > j; j++) {
                if (nums[i] == nums[j] and (i * j) % k == 0)
                    cnt++;
            }
        }
        return cnt;
    }
};
